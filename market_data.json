import requests
from bs4 import BeautifulSoup
import xml.etree.ElementTree as ET
import json
from datetime import datetime
import pytz

def get_market_data():
    # --- 1. LẤY GIÁ XĂNG DẦU (PETROLIMEX) ---
    petro_url = 'https://www.petrolimex.com.vn/'
    headers = {'User-Agent': 'Mozilla/5.0'}
    xang_dau_results = {}
    
    try:
        res_petro = requests.get(petro_url, headers=headers)
        res_petro.raise_for_status()
        soup = BeautifulSoup(res_petro.text, 'html.parser')
        
        target_items = ["DO 0,05S-II", "Xăng RON 95-V", "Xăng RON 95-III", "DO 0,001S-V"]
        price_container = soup.find('div', class_='header__pricePetrol')
        
        if price_container:
            for row in price_container.find_all('tr'):
                cols = row.find_all('td')
                if len(cols) >= 3:
                    name = cols[0].text.strip()
                    if name in target_items:
                        xang_dau_results[name] = {
                            "vung_1": cols[1].text.strip(),
                            "vung_2": cols[2].text.strip()
                        }
    except Exception as e:
        print(f"Lỗi lấy giá xăng: {e}")

    # --- 2. LẤY GIÁ VÀNG (BẢO TÍN MINH CHÂU) ---
    btmc_url = 'http://api.btmc.vn/api/BTMCAPI/getpricebtmc?key=3kd8ub1llcg9t45hnoh8hmn7t5kc2v'
    gia_vang_results = {}
    
    try:
        res_btmc = requests.get(btmc_url)
        res_btmc.raise_for_status()
        # Đọc dữ liệu XML
        root = ET.fromstring(res_btmc.content)
        
        # Tìm tất cả thẻ <Data>
        for child in root.findall('Data'):
            ten_vang = child.get('n_1')
            
            # Lọc lấy những loại vàng bạn quan tâm (Ví dụ: Vàng Rồng Thăng Long và Vàng SJC)
            if ten_vang and ('Vàng Rồng Thăng Long' in ten_vang or 'Vàng SJC' in ten_vang):
                gia_vang_results[ten_vang.strip()] = {
                    "mua_vao": child.get('pb_1'),
                    "ban_ra": child.get('ps_1'),
                    "cap_nhat_goc": child.get('d_1') # Thời gian cập nhật từ phía BTMC
                }
    except Exception as e:
        print(f"Lỗi lấy giá vàng: {e}")

    # --- 3. GỘP DỮ LIỆU VÀ LƯU RA FILE JSON ---
    tz_VN = pytz.timezone('Asia/Ho_Chi_Minh')
    datetime_VN = datetime.now(tz_VN)

    final_data = {
        "thoi_gian_dong_bo": datetime_VN.strftime('%Y-%m-%d %H:%M:%S'),
        "xang_dau": xang_dau_results,
        "gia_vang": gia_vang_results
    }

    # Lưu thành file market_data.json
    with open('market_data.json', 'w', encoding='utf-8') as f:
        json.dump(final_data, f, ensure_ascii=False, indent=4)
        
    print("✅ Đã gộp và tạo file market_data.json thành công!")
    print(json.dumps(final_data, ensure_ascii=False, indent=2))

if __name__ == "__main__":
    get_market_data()
